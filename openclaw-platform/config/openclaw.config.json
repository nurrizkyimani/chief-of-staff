{
  "agents": {
    "defaults": {
      "model": {
        "primary": "mistral/mistral-small-latest"
      },
      "sandbox": {
        "mode": "all",
        "backend": "docker",
        "scope": "session",
        "workspaceAccess": "rw",
        "docker": {
          "image": "openclaw-sandbox:bookworm-slim",
          "network": "none"
        }
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "allowlist",
      "capabilities": {
        "inlineButtons": "allowlist"
      },
      "customCommands": [
        {
          "command": "modelhealth",
          "description": "Check Mistral model connectivity"
        }
      ],
      "allowFrom": [
        "telegram:380399260"
      ],
      "groupAllowFrom": [
        "telegram:380399260"
      ],
      "groups": {
        "*": {
          "requireMention": true
        }
      }
    }
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "load": {
        "extraDirs": [
          "/Users/nurrizky/dev/chief-of-staff/openclaw-platform/hooks"
        ]
      },
      "entries": {
        "receipt-intake": {
          "enabled": true
        }
      }
    }
  },
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token"
    }
  },
  "plugins": {
    "entries": {
      "openai": {
        "enabled": false
      }
    }
  }
}
