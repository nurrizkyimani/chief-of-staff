{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "receipt.v1.1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "receipt.v1.1"
    },
    "receipt_id": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "platform": {
          "const": "telegram"
        },
        "chat_id": {
          "type": "string",
          "minLength": 1
        },
        "message_id": {
          "type": "string",
          "minLength": 1
        },
        "received_at": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "platform",
        "chat_id",
        "message_id",
        "received_at"
      ]
    },
    "merchant_name": {
      "type": "string",
      "minLength": 1
    },
    "receipt_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "total_amount": {
      "type": "number"
    },
    "tax_amount": {
      "type": "number"
    },
    "tax_label_raw": {
      "type": "string"
    },
    "classification": {
      "type": "string",
      "enum": [
        "food",
        "mobility",
        "groceries",
        "nonfood",
        "subscription"
      ]
    },
    "currency": {
      "type": "string"
    },
    "month_key": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}$"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "needs_review": {
      "type": "boolean"
    },
    "raw_json": {
      "type": "object"
    }
  },
  "required": [
    "schema_version",
    "receipt_id",
    "source",
    "merchant_name",
    "receipt_date",
    "total_amount",
    "tax_amount",
    "tax_label_raw",
    "classification",
    "currency",
    "month_key",
    "confidence",
    "needs_review",
    "raw_json"
  ]
}
